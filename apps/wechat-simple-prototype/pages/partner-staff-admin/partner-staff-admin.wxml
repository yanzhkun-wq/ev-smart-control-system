<view class="gate" wx:if="{{!ok}}">

  <view class="gate-inner">

    <block wx:if="{{loadError}}">

      <text class="gate-t">员工工作台</text>

      <text class="gate-s">{{loadError}}</text>

      <button class="gate-btn" bindtap="retryRefresh">重试</button>

      <button class="gate-btn ghost" bindtap="toUser">切换到用户端</button>

    </block>

    <block wx:else>

      <text class="gate-t">加载中…</text>

    </block>

  </view>

</view>



<view class="shell" wx:if="{{ok}}">

  <view class="demo-preview-bar" wx:if="{{demoPreview}}">

    <text class="demo-preview-t">预览 · {{demoPreviewMask}}</text>

  </view>



  <view class="hero hero-compact hero-plain">

    <text class="hero-title">员工工作台</text>

    <text class="hero-sub" wx:if="{{workspace}}">{{tierLabel}} · {{workspace.displayName}}</text>

    <text class="hero-meta">{{phoneMask}}</text>

  </view>



  <view class="tabs tabs-two">    <view class="tab {{activeTab == 0 ? 'on' : ''}}" data-i="0" bindtap="setTab">工作台</view>

    <view class="tab {{activeTab == 1 ? 'on' : ''}}" data-i="1" bindtap="setTab">结算记录</view>

  </view>



  <view class="wallet-strip" bindtap="openWallet">

    <text class="wallet-strip-k">可提现 ¥{{walletAvailable}}</text>

    <text class="wallet-strip-h" wx:if="{{walletPendingOut !== '0'}}">处理中 ¥{{walletPendingOut}}</text>

    <text class="wallet-strip-a">提现 ›</text>

  </view>



  <view class="wallet-strip wallet-strip-secondary" bindtap="openUserLookup">

    <text class="wallet-strip-k">客户装机查询</text>

    <text class="wallet-strip-a">›</text>

  </view>



  <view class="body body-tight">

    <block wx:if="{{activeTab == 0}}">

      <block wx:if="{{workspace && workspace.tier === 'L1'}}">

        <view class="dash-card dash-card-simple">

          <text class="dash-h">拓客概况</text>

          <view class="metrics-bar metrics-two">

            <view class="mcell">

              <text class="mv">{{workspace.stats.merchantTotal}}</text>

              <text class="mk">邀请商家</text>

            </view>

            <view class="mcell">

              <text class="mv">{{workspace.stats.userTotal}}</text>

              <text class="mk">邀请用户</text>

            </view>

          </view>

        </view>

      </block>



      <block wx:if="{{workspace && workspace.tier === 'L2'}}">

        <view class="dash-card dash-card-simple">

          <text class="dash-h">拓客概况</text>

          <view class="metrics-bar metrics-two">

            <view class="mcell">

              <text class="mv">{{workspace.merchants}}</text>

              <text class="mk">邀请商家</text>

            </view>

            <view class="mcell">

              <text class="mv">{{workspace.users}}</text>

              <text class="mk">邀请用户</text>

            </view>

          </view>

          <text class="weight-line weight-muted" wx:if="{{workspace.parentHint}}">{{workspace.parentHint}}</text>

        </view>

      </block>



      <view class="dash-card">

        <text class="dash-h">分享拓展</text>

        <view class="share-row share-row-inline">

          <button class="share-half" open-type="share" data-kind="merchant">商家入驻</button>

          <button class="share-half share-user" open-type="share" data-kind="user">用户绑定</button>

        </view>

      </view>



      <view class="dash-card" wx:if="{{myInvites.length}}">

        <text class="dash-h">我的拓客 · {{myInvites.length}} 条</text>

        <scroll-view scroll-y class="scroll-inv-tight">

          <view class="inv inv-tight" wx:for="{{myInvites}}" wx:for-index="ix" wx:key="ix">

            <view class="inv-head">

              <text class="inv-kind {{item.kind === '用户' ? 'inv-kind-user' : ''}}">{{item.kind}}</text>

              <text class="inv-time">{{item.at}}</text>

            </view>

            <text class="inv-line">{{item.inviteeMask}} · {{item.extra}}</text>

          </view>

        </scroll-view>

      </view>

      <view class="dash-card dash-card-muted" wx:else>

        <text class="dash-h">我的拓客</text>

        <text class="empty-inline">使用上方分享后，记录会出现在这里</text>

      </view>

    </block>



    <block wx:if="{{activeTab == 1}}">

      <view class="dash-card">

        <text class="dash-h">我的结算</text>

        <scroll-view scroll-y class="scroll-tight" wx:if="{{incomeRows.length}}">

          <view class="rw rw-tight" wx:for="{{incomeRows}}" wx:key="id">

            <view class="rw-top">

              <text class="rw-amt">+¥{{item.rewardYuan}}</text>

              <text class="pill">{{item.sourceType}}</text>

            </view>

            <text class="rw-bot">{{item.settledAt}}</text>

          </view>

        </scroll-view>

        <text class="empty" wx:else>暂无记录</text>

      </view>

    </block>

  </view>



  <button class="foot" bindtap="toUser">切换到用户端</button>

</view>

