.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: linear-gradient(180deg, #eef2f7 0%, #f8fafc 35%);
}

.safe-bottom {
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 28rpx rgba(15, 23, 42, 0.06);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
}

.intro {
  padding: 26rpx 28rpx;
  margin-bottom: 20rpx;
}

.intro-t {
  font-size: 32rpx;
  font-weight: 800;
  color: #0f172a;
  display: block;
}

.intro-s {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.45;
  display: block;
}

.push-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 22rpx 24rpx;
  margin-bottom: 20rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #eef2ff 0%, #fff 100%);
  border: 1rpx solid #c7d2fe;
  box-shadow: 0 8rpx 24rpx rgba(99, 102, 241, 0.08);
}

.push-inner {
  flex: 1;
  min-width: 0;
}

.push-t {
  font-size: 28rpx;
  font-weight: 800;
  color: #3730a3;
  display: block;
}

.push-s {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6366f1;
  line-height: 1.4;
  display: block;
}

.push-arr {
  font-size: 36rpx;
  color: #a5b4fc;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.handle-row {
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #f1f5f9;
}

.btn-handle {
  text-align: center;
  padding: 22rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 800;
  color: #fff;
  background: linear-gradient(135deg, #4f46e5, #6366f1);
}

.stats {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 28rpx;
}

.stat {
  flex: 1 1 42%;
  min-width: 140rpx;
  padding: 20rpx 10rpx;
  text-align: center;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
  box-sizing: border-box;
}

.stat-active {
  border-color: #a5b4fc;
  background: linear-gradient(180deg, #eef2ff 0%, #fff 100%);
  box-shadow: 0 8rpx 24rpx rgba(99, 102, 241, 0.12);
}

.stat-press {
  opacity: 0.92;
  transform: scale(0.98);
}

.filter-hint {
  margin: -12rpx 6rpx 20rpx;
  font-size: 24rpx;
  color: #6366f1;
  font-weight: 700;
}

.sv {
  font-size: 36rpx;
  font-weight: 800;
  color: #4f46e5;
  display: block;
}

.sl {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #6b7280;
  display: block;
  line-height: 1.25;
}

.smart {
  padding: 24rpx 26rpx;
  margin-bottom: 20rpx;
}

.smart-t {
  font-size: 28rpx;
  font-weight: 800;
  color: #0f172a;
  display: block;
  margin-bottom: 14rpx;
}

.smart-p {
  font-size: 24rpx;
  color: #475569;
  line-height: 1.5;
  display: block;
  margin-top: 10rpx;
}

.sec-head {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin: 8rpx 6rpx 16rpx;
}

.sec-l {
  flex: 1;
  min-width: 0;
}

.sec-sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #b45309;
  font-weight: 700;
  line-height: 1.35;
  display: block;
}

.sec-head-done {
  margin-top: 32rpx;
}

.sec-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #0f172a;
}

.sec-count {
  font-size: 24rpx;
  color: #94a3b8;
  font-weight: 600;
  flex-shrink: 0;
}

.item-badges {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
  flex-shrink: 0;
}

.risk-pill {
  font-size: 20rpx;
  font-weight: 800;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
}

.risk-hi {
  background: #fef2f2;
  color: #b91c1c;
  border: 1rpx solid #fecaca;
}

.risk-mid {
  background: #fffbeb;
  color: #b45309;
  border: 1rpx solid #fde68a;
}

.risk-lo {
  background: #f1f5f9;
  color: #475569;
  border: 1rpx solid #e2e8f0;
}

.smart-why {
  font-size: 24rpx;
  color: #334155;
  line-height: 1.5;
  display: block;
  margin-bottom: 12rpx;
  padding: 16rpx 18rpx;
  background: #f8fafc;
  border-radius: 14rpx;
  border: 1rpx solid #e2e8f0;
}

.smart-why-done {
  color: #64748b;
  background: #fafafa;
}

.sw-lab,
.sg-lab {
  font-weight: 800;
  color: #4f46e5;
}

.suggest {
  font-size: 24rpx;
  color: #0f172a;
  line-height: 1.5;
  display: block;
  margin-top: 12rpx;
  padding: 16rpx 18rpx;
  background: #eef2ff;
  border-radius: 14rpx;
  border: 1rpx solid #c7d2fe;
}

.suggest-done {
  background: #f1f5f9;
  border-color: #e2e8f0;
  color: #475569;
}

.suggest-done .sg-lab {
  color: #6366f1;
}

.empty {
  padding: 36rpx 28rpx;
  margin-bottom: 20rpx;
  text-align: center;
  background: #f8fafc;
  border: 1rpx dashed #e2e8f0;
}

.empty-t {
  font-size: 28rpx;
  color: #64748b;
  font-weight: 600;
  display: block;
}

.empty-s {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #9ca3af;
  display: block;
}

.item {
  padding: 24rpx 26rpx;
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 28rpx rgba(15, 23, 42, 0.06);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
}

.item-pending {
  border-left: 6rpx solid #f59e0b;
}

.item-done {
  border-left: 6rpx solid #22c55e;
  opacity: 0.98;
}

.item-top {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.type-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.type-ico {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  color: #fff;
  font-size: 28rpx;
  flex-shrink: 0;
}

.type-ico.y {
  background: linear-gradient(135deg, #eab308, #ca8a04);
}

.type-ico.g {
  background: linear-gradient(135deg, #22c55e, #16a34a);
}

.type-ico.r {
  background: linear-gradient(135deg, #ef4444, #dc2626);
}

.type-mid {
  flex: 1;
  min-width: 0;
}

.type-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #0f172a;
  line-height: 1.35;
  display: block;
}

.type-tag {
  margin-top: 8rpx;
  display: inline-block;
  font-size: 20rpx;
  font-weight: 700;
  color: #6366f1;
  background: #eef2ff;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
}

.pill {
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 800;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
}

.pill-warn {
  background: #fff7ed;
  color: #c2410c;
  border: 1rpx solid #fdba74;
}

.pill-ok {
  background: #ecfdf5;
  color: #047857;
  border: 1rpx solid #6ee7b7;
}

.item-desc {
  font-size: 26rpx;
  color: #475569;
  line-height: 1.5;
  display: block;
}

.item-foot {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.item-time {
  font-size: 24rpx;
  color: #64748b;
  font-weight: 600;
}

.item-handled {
  font-size: 24rpx;
  color: #059669;
  font-weight: 600;
}

.item-addr {
  font-size: 22rpx;
  color: #94a3b8;
  line-height: 1.4;
}

.item-addr-done {
  margin-top: 10rpx;
  display: block;
}

button::after {
  border: none;
}
