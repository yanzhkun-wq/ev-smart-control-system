.gate {
  min-height: 100vh;
  padding: 48rpx 32rpx;
  box-sizing: border-box;
  background: #e8edf3;
}
.gate-inner {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  border: 1rpx solid #e2e8f0;
}
.gate-t {
  font-size: 30rpx;
  font-weight: 800;
  color: #0f172a;
  display: block;
}
.gate-s {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.5;
  display: block;
}

.page {
  height: 100vh;
  background: #e8edf3;
  box-sizing: border-box;
}
.banner {
  margin: 20rpx 20rpx 0;
  padding: 22rpx;
  background: #fffbeb;
  border: 1rpx solid #fde68a;
  border-radius: 14rpx;
}
.banner-t {
  font-size: 28rpx;
  font-weight: 800;
  color: #92400e;
  display: block;
}
.banner-s {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #a16207;
  line-height: 1.5;
  display: block;
}

.seg {
  display: flex;
  flex-direction: row;
  margin: 20rpx 20rpx 0;
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #e2e8f0;
}
.seg-three .seg-i {
  padding: 18rpx 6rpx;
  font-size: 22rpx;
}
.seg-i {
  flex: 1;
  text-align: center;
  padding: 22rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #64748b;
  background: #f8fafc;
}
.seg-i.on {
  background: #0f172a;
  color: #fff;
}

.panel {
  margin: 16rpx 20rpx 0;
  background: #fff;
  border-radius: 16rpx;
  padding: 22rpx;
  border: 1rpx solid #cbd5e1;
}
.lab {
  font-size: 26rpx;
  font-weight: 700;
  color: #334155;
  display: block;
}
.lab-mt {
  margin-top: 18rpx;
}
.hint {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #94a3b8;
  line-height: 1.45;
  display: block;
}
.inp {
  margin-top: 12rpx;
  height: 84rpx;
  padding: 0 20rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  font-size: 28rpx;
  background: #f8fafc;
}

.btn {
  margin: 28rpx 20rpx 0;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 14rpx;
  font-weight: 800;
  background: #0f172a;
  color: #fff;
}
.foot-sp {
  height: calc(48rpx + env(safe-area-inset-bottom));
}
