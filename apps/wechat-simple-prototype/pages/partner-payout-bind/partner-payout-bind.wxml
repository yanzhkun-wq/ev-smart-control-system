<view class="gate" wx:if="{{!ok}}">
  <view class="gate-inner">
    <text class="gate-t">绑定收款账户</text>
    <text class="gate-s">{{loadError}}</text>
  </view>
</view>

<scroll-view scroll-y class="page" wx:if="{{ok}}">
  <view class="banner">
    <text class="banner-t">收款方式</text>
    <text class="banner-s">请选择微信零钱、支付宝或银行卡，并填写与账户一致的信息。到账时间与规则以实际支付渠道为准。</text>
  </view>

  <view class="seg seg-three">
    <view class="seg-i {{channel === 'wechat_wallet' ? 'on' : ''}}" bindtap="setChannelWx">微信零钱</view>
    <view class="seg-i {{channel === 'alipay' ? 'on' : ''}}" bindtap="setChannelAli">支付宝</view>
    <view class="seg-i {{channel === 'bank_card' ? 'on' : ''}}" bindtap="setChannelBank">银行卡</view>
  </view>

  <view class="panel" wx:if="{{channel === 'wechat_wallet'}}">
    <text class="lab">真实姓名</text>
    <text class="hint">须与微信实名一致。</text>
    <input class="inp" placeholder="例如：张三" value="{{realName}}" bindinput="onRealName" />
  </view>

  <view class="panel" wx:if="{{channel === 'alipay'}}">
    <text class="lab">真实姓名</text>
    <text class="hint">须与支付宝实名一致。</text>
    <input class="inp" placeholder="例如：张三" value="{{realName}}" bindinput="onRealName" />
    <text class="lab lab-mt">支付宝账号</text>
    <text class="hint">绑定手机号或邮箱。</text>
    <input class="inp" placeholder="手机号或邮箱" value="{{alipayAccount}}" bindinput="onAlipayAccount" />
  </view>

  <view class="panel" wx:if="{{channel === 'bank_card'}}">
    <text class="lab">开户名</text>
    <input class="inp" placeholder="持卡人姓名" value="{{holderName}}" bindinput="onHolder" />
    <text class="lab lab-mt">开户银行</text>
    <input class="inp" placeholder="如：招商银行北京分行" value="{{bankName}}" bindinput="onBankName" />
    <text class="lab lab-mt">银行卡号</text>
    <input class="inp" type="digit" maxlength="19" placeholder="16–19 位完整卡号" value="{{bankCardNo}}" bindinput="onBankCard" />
    <text class="hint">打款需完整卡号；请勿在公开场合展示。</text>
  </view>

  <button class="btn" bindtap="save">保存</button>
  <view class="foot-sp"></view>
</scroll-view>
