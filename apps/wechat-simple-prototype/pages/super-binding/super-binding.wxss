.page {
  padding: 24rpx;
  min-height: 100vh;
  background: #fef2f2;
}
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 26rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #fecaca;
}
.t {
  font-size: 30rpx;
  font-weight: 800;
  color: #991b1b;
  display: block;
}
.s {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.4;
  display: block;
}
.lab {
  font-size: 26rpx;
  font-weight: 700;
  color: #334155;
  display: block;
  margin-bottom: 10rpx;
}
.lab-mt {
  margin-top: 16rpx;
}
.inp {
  height: 80rpx;
  padding: 0 20rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  font-size: 26rpx;
}
.btn {
  margin-top: 24rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 14rpx;
  font-weight: 800;
  color: #fff;
  background: #b91c1c;
}
.subt {
  font-size: 26rpx;
  font-weight: 800;
  color: #0f172a;
  margin-bottom: 16rpx;
  display: block;
}
.row {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}
.rp {
  font-size: 28rpx;
  font-weight: 800;
  color: #0f172a;
  display: block;
}
.ri {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #64748b;
  display: block;
}
.empty {
  font-size: 26rpx;
  color: #94a3b8;
}
.bad-t {
  font-size: 26rpx;
  color: #b91c1c;
  line-height: 1.45;
}

.card-neutral {
  border-color: #c7d2fe;
  background: linear-gradient(180deg, #f8fafc 0%, #fff 100%);
}
.t-neutral {
  font-size: 30rpx;
  font-weight: 800;
  color: #1e1b4b;
  display: block;
}
.s-neutral {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.45;
  display: block;
}
.tool-row {
  margin-top: 22rpx;
  padding: 20rpx 18rpx;
  border-radius: 16rpx;
  background: #eef2ff;
  border: 1rpx solid #c7d2fe;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}
.tool-ico {
  width: 64rpx;
  height: 64rpx;
  border-radius: 14rpx;
  background: linear-gradient(145deg, #6366f1, #4338ca);
  color: #fff;
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.tool-body {
  flex: 1;
  min-width: 0;
}
.tool-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #0f172a;
  display: block;
}
.tool-sub {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #64748b;
  display: block;
}
.tool-arr {
  font-size: 36rpx;
  color: #a5b4fc;
  font-weight: 300;
  flex-shrink: 0;
}
