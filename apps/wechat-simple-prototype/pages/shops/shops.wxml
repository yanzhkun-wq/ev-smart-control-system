<view class="page safe-bottom">
  <view class="head">
    <text class="head-title">同城合作网点</text>
    <view class="loc-row">
      <text class="loc-txt">{{locLabel}}</text>
      <view class="loc-btn" bindtap="refreshLocation">更新定位</view>
    </view>
  </view>

  <view class="filter-card">
    <view class="filter-row">
      <text class="filter-lab">行政区</text>
      <picker mode="selector" range="{{districtLabels}}" value="{{districtIndex}}" bindchange="onDistrictChange">
        <view class="filter-pick">
          <text class="filter-val">{{districtLabels[districtIndex]}}</text>
          <text class="filter-arr">›</text>
        </view>
      </picker>
    </view>
    <view class="filter-row">
      <text class="filter-lab">距离</text>
      <picker mode="selector" range="{{distanceLabels}}" value="{{distanceIndex}}" bindchange="onDistanceChange">
        <view class="filter-pick {{locDenied ? 'filter-pick-dis' : ''}}">
          <text class="filter-val">{{distanceLabels[distanceIndex]}}{{locDenied ? '（需定位）' : ''}}</text>
          <text class="filter-arr">›</text>
        </view>
      </picker>
    </view>
  </view>

  <view class="card tip" wx:if="{{locDenied}}">
    <text class="tip-t">未授权位置</text>
    <text class="tip-s">授权后可按距离筛选；仍可浏览全部网点。</text>
  </view>

  <block wx:for="{{shops}}" wx:key="id">
    <view class="card shop">
      <view class="shop-top">
        <image wx:if="{{item.storefrontImage}}" class="shop-img" src="{{item.storefrontImage}}" mode="aspectFill" />
        <view wx:else class="shop-ph">
          <text class="shop-ph-t">网点</text>
        </view>
        <view class="shop-body">
          <text class="shop-name">{{item.shopName}}</text>
          <text class="shop-meta">{{item.city}} · {{item.district}} · 距您 {{item.distanceLabel}}</text>
          <text class="shop-addr">{{item.addressFull}}</text>
        </view>
      </view>
      <view class="shop-row">
        <text class="shop-boss">老板 {{item.bossName}}</text>
        <view class="shop-actions">
          <view class="mini" bindtap="callShop" data-phone="{{item.contactPhone}}">电话</view>
          <view class="mini primary" bindtap="openMap" data-id="{{item.id}}">导航</view>
        </view>
      </view>
    </view>
  </block>

  <view class="empty" wx:if="{{shops.length === 0}}">
    <text>暂无符合条件的网点</text>
  </view>

  <view class="foot-hint">
    <text>平台补贴：到店完成的加装服务可按规则享受定额补贴（演示）</text>
  </view>
</view>
