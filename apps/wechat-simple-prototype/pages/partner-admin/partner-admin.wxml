<view class="gate" wx:if="{{!ok}}">
  <view class="gate-inner">
    <block wx:if="{{loadError}}">
      <text class="gate-t">合作商工作台</text>
      <text class="gate-s">{{loadError}}</text>
      <button class="gate-btn" bindtap="retryRefresh">重试</button>
      <button class="gate-btn ghost" bindtap="toUser">切换到用户端</button>
    </block>
    <block wx:else>
      <text class="gate-t">加载中…</text>
    </block>
  </view>
</view>

<view class="shell" wx:if="{{ok}}">
  <view class="tier-hero" wx:if="{{tierSummary}}">
    <view class="tier-hero-main">
      <view class="tier-left">
        <text class="tier-badge">{{tierSummary.tierLabel}}</text>
        <text class="tier-sub">上门补贴计提 {{tierSummary.tierRatePct}}%</text>
      </view>
      <view class="tier-right">
        <text class="tier-num">{{tierSummary.attributedUserCount}}</text>
        <text class="tier-num-cap">有效用户</text>
      </view>
    </view>
    <block wx:if="{{!tierSummary.isMaxTier}}">
      <view class="tier-track">
        <view class="tier-fill" style="width: {{tierSummary.progressPct}}%;"></view>
      </view>
      <view class="tier-next">
        <text class="tier-next-strong">距 {{tierSummary.nextTierLabel}} 还差 {{tierSummary.usersToNext}} 户</text>
        <text class="tier-next-weak">下一档 {{tierSummary.nextTierRatePct}}%</text>
      </view>
    </block>
    <text class="tier-max" wx:else>已达最高等级 · 计提 {{tierSummary.tierRatePct}}%</text>
    <text class="tier-meta">{{phoneMask}} · 主管 {{rootMask}}</text>
  </view>

  <view class="tabs tabs-four">    <view class="tab {{activeTab == 0 ? 'on' : ''}}" data-i="0" bindtap="setTab">概览</view>
    <view class="tab {{activeTab == 1 ? 'on' : ''}}" data-i="1" bindtap="setTab">团队</view>
    <view class="tab {{activeTab == 2 ? 'on' : ''}}" data-i="2" bindtap="setTab">明细</view>
    <view class="tab {{activeTab == 3 ? 'on' : ''}}" data-i="3" bindtap="setTab">商家审核</view>
  </view>

  <view class="body">
    <block wx:if="{{activeTab == 0}}">
      <block wx:if="{{dashboard}}">
      <view class="pending-bar" wx:if="{{pendingCount > 0}}" bindtap="openPendingTab">
        <text class="pending-bar-t">待审核商家 {{pendingCount}} 家</text>
        <text class="pending-bar-a">去处理 ›</text>
      </view>

      <view class="wallet-entry" bindtap="openWallet">
        <view class="wallet-entry-l">
          <text class="wallet-entry-t">佣金提现</text>
          <text class="wallet-entry-s">可提现 ¥{{walletAvailable}} · 处理中 ¥{{walletPendingOut}}</text>
        </view>
        <text class="wallet-entry-a">›</text>
      </view>

      <view class="wallet-entry" bindtap="openUserLookup">
        <view class="wallet-entry-l">
          <text class="wallet-entry-t">客户装机查询</text>
          <text class="wallet-entry-s">按手机号、车牌或网点 / 店主名称查询</text>
        </view>
        <text class="wallet-entry-a">›</text>
      </view>

      <view class="panel panel-compact">
        <text class="panel-h">区间业绩 · {{periodLabel}}</text>
        <view class="p-chips p-chips-tight">
          <text class="p-chip {{periodPreset == 'today' ? 'on' : ''}}" data-p="today" bindtap="setPeriod">今日</text>
          <text class="p-chip {{periodPreset == 'week' ? 'on' : ''}}" data-p="week" bindtap="setPeriod">本周</text>
          <text class="p-chip {{periodPreset == 'month' ? 'on' : ''}}" data-p="month" bindtap="setPeriod">本月</text>
          <text class="p-chip {{periodPreset == 'year' ? 'on' : ''}}" data-p="year" bindtap="setPeriod">本年</text>
        </view>
        <view class="p-custom">
          <picker mode="date" value="{{customStart}}" bindchange="onPickStart">
            <view class="p-date">起 {{customStart}}</view>
          </picker>
          <picker mode="date" value="{{customEnd}}" bindchange="onPickEnd">
            <view class="p-date">止 {{customEnd}}</view>
          </picker>
          <view class="p-query" bindtap="applyCustomRange">查询</view>
        </view>

        <view class="perf-inline-row">
          <view class="perf-inline-col {{overviewPerfSide === 'direct' ? 'perf-inline-col-on' : ''}}">
            <view
              class="perf-tile perf-tile-direct {{overviewPerfSide === 'direct' ? 'perf-tile-on' : ''}}"
              data-side="direct"
              bindtap="selectPerfSide"
              hover-class="perf-tile-hover"
            >
              <text class="perf-tile-k">直营</text>
              <text class="perf-tile-v">¥{{periodStats.rootLineReward}}</text>
              <text class="perf-tile-hint">主管拓客 · 点看本区订单</text>
            </view>
            <view class="perf-inline-panel" wx:if="{{overviewPerfSide === 'direct'}}">
              <text class="perf-inline-meta">{{periodLabel}}</text>
              <scroll-view scroll-y class="perf-inline-scroll" wx:if="{{directRewardRows.length}}">
                <view class="po-row po-row-compact" wx:for="{{directRewardRows}}" wx:key="id">
                  <view class="po-top">
                    <text class="po-amt">+¥{{item.rewardYuan}}</text>
                    <text class="pill {{item.sourceType === '直营' ? 'pill-b' : 'pill-o'}}">{{item.sourceType}}</text>
                  </view>
                  <text class="po-mid">门店 {{item.merchantMask}} · 基数 ¥{{item.orderAmountYuan}}</text>
                  <text class="po-rate" wx:if="{{item.rateText}}">{{item.rateText}}</text>
                  <text class="po-bot">拓客 {{item.inviterMask}} · {{item.settledAt}}</text>
                </view>
              </scroll-view>
              <text class="perf-empty perf-empty-inline" wx:else>暂无结算单</text>
            </view>
          </view>

          <view class="perf-inline-col {{overviewPerfSide === 'team' ? 'perf-inline-col-on' : ''}}">
            <view
              class="perf-tile perf-tile-team {{overviewPerfSide === 'team' ? 'perf-tile-on' : ''}}"
              data-side="team"
              bindtap="selectPerfSide"
              hover-class="perf-tile-hover"
            >
              <text class="perf-tile-k">团队</text>
              <text class="perf-tile-v">¥{{periodStats.teamLineReward}}</text>
              <text class="perf-tile-hint">员工拓客 · 点看本区订单</text>
            </view>
            <view class="perf-inline-panel" wx:if="{{overviewPerfSide === 'team'}}">
              <text class="perf-inline-meta">{{periodLabel}}</text>
              <scroll-view scroll-y class="perf-inline-scroll" wx:if="{{teamRewardRows.length}}">
                <view class="po-row po-row-compact" wx:for="{{teamRewardRows}}" wx:key="id">
                  <view class="po-top">
                    <text class="po-amt">+¥{{item.rewardYuan}}</text>
                    <text class="pill {{item.sourceType === '直营' ? 'pill-b' : 'pill-o'}}">{{item.sourceType}}</text>
                  </view>
                  <text class="po-mid">门店 {{item.merchantMask}} · 基数 ¥{{item.orderAmountYuan}}</text>
                  <text class="po-line">归属 {{item.bucketLabel}}</text>
                  <text class="po-rate" wx:if="{{item.rateText}}">{{item.rateText}}</text>
                  <text class="po-bot">拓客 {{item.inviterMask}} · {{item.settledAt}}</text>
                </view>
              </scroll-view>
              <text class="perf-empty perf-empty-inline" wx:else>暂无结算单</text>
            </view>
          </view>
        </view>
      </view>

      <view class="panel panel-compact">
        <text class="panel-h">拓客分享</text>
        <view class="share-row share-row-tight">
          <button class="share share-dual" open-type="share" data-kind="merchant">商家入驻</button>
          <button class="share share-dual share-user" open-type="share" data-kind="user">用户绑定</button>
        </view>
        <button wx:if="{{isPrincipal}}" class="share share-partner-invite" open-type="share" data-kind="partner_partner">邀请合作商主管</button>
        <view class="pip-panel" wx:if="{{isPrincipal}}">
          <text class="pip-panel-h">合作商邀请奖励（演示）· {{partnerInviteRewardsCount}} 笔</text>
          <text class="pip-panel-s">代理费按 ¥{{demoPartnerAgencyFeeYuan}} / 户；含 10% 平台补贴 + 档位级差。</text>
          <scroll-view scroll-y class="pip-scroll" wx:if="{{partnerInviteRewards.length}}">
            <view class="pip-row" wx:for="{{partnerInviteRewards}}" wx:key="id">
              <view class="pip-top">
                <text class="pip-amt">+¥{{item.totalYuan}}</text>
                <text class="pip-time">{{item.settledAt}}</text>
              </view>
              <text class="pip-line">被邀请 {{item.inviteeMask}} · 代理费 ¥{{item.agencyFeeYuan}}</text>
              <text class="pip-note">补贴 ¥{{item.referralYuan}} · 级差 ¥{{item.tierDiffYuan}}（{{item.inviterTierLabel}}{{item.inviterTierPct}}% − {{item.inviteeTierLabel}}{{item.inviteeTierPct}}%）</text>
            </view>
          </scroll-view>
          <text class="pip-empty" wx:else>暂无记录</text>
        </view>
      </view>
      </block>
      <view class="panel" wx:else>
        <text class="panel-h">加载中</text>
        <text class="panel-s">正在拉取数据…</text>
      </view>
    </block>

    <block wx:if="{{activeTab == 2}}">
      <view class="seg seg-page-top">
        <view class="seg-i {{detailTab == 'flow' ? 'on' : ''}}" data-t="flow" bindtap="setDetailTab">结算流水</view>
        <view class="seg-i {{detailTab == 'ledger' ? 'on' : ''}}" data-t="ledger" bindtap="setDetailTab">商家台账</view>
      </view>
      <view class="panel panel-compact" wx:if="{{detailTab == 'flow'}}">
        <text class="panel-h">结算流水 · {{incomeCount}}</text>
        <scroll-view scroll-y class="income-scroll" wx:if="{{incomeRows.length}}">
          <view class="rw rw-tight" wx:for="{{incomeRows}}" wx:key="id">
            <view class="rw-line1">
              <text class="rw-amt">+¥{{item.rewardYuan}}</text>
              <text class="pill {{item.sourceType === '直营' ? 'pill-b' : 'pill-o'}}">{{item.sourceType}}</text>
            </view>
            <text class="rw-line2">基数 ¥{{item.orderAmountYuan}} · {{item.merchantMask}}</text>
            <text class="rw-line3">{{item.inviterMask}} · {{item.bucketLabel}} · {{item.settledAt}}</text>
          </view>
        </scroll-view>
        <text class="empty" wx:else>暂无</text>
      </view>
      <view class="panel panel-compact" wx:if="{{detailTab == 'ledger'}}">
        <text class="panel-h">商家台账 · {{inviteLedgerCount}}</text>
        <scroll-view scroll-y class="ledger-scroll" wx:if="{{inviteLedger.length}}">
          <view class="ld-row ld-row-tight" wx:for="{{inviteLedger}}" wx:for-index="ldx" wx:key="ldx">
            <view class="ld-head">
              <text class="ld-kind ld-kind-merch">门店</text>
              <text class="ld-time">{{item.at}}</text>
            </view>
            <text class="ld-line">{{item.inviteeMask}} · {{item.extra}}</text>
            <text class="ld-inv">邀请 {{item.inviterLabel}}</text>
          </view>
        </scroll-view>
        <text class="empty" wx:else>暂无</text>
      </view>
    </block>

    <block wx:if="{{activeTab == 1}}">
      <view class="org-hero org-hero-compact" wx:if="{{isPrincipal}}">
        <text class="org-hero-t">团队管理</text>
      </view>

      <view class="panel panel-tight panel-compact" wx:if="{{isPrincipal}}">
        <text class="panel-h">新增员工账号</text>
        <view class="seg seg-mt">
          <view class="seg-i {{newTier === 'L1' ? 'on' : ''}}" bindtap="setTierL1">一级</view>
          <view class="seg-i {{newTier === 'L2' ? 'on' : ''}}" bindtap="setTierL2">二级</view>
        </view>
        <text class="lab">手机号</text>
        <input class="inp" type="number" maxlength="11" placeholder="11 位" value="{{newStaffPhone}}" bindinput="onNewStaffPhone" />
        <text class="lab lab-mt">称呼</text>
        <input class="inp" placeholder="选填" value="{{newStaffName}}" bindinput="onNewStaffName" />
        <text class="lab lab-mt">分佣比例（占体系已计提佣金 %）</text>
        <input class="inp" type="number" placeholder="0–100，如 10 表示从计提池切 10%" value="{{newStaffPct}}" bindinput="onNewStaffPct" />
        <text class="lab lab-mt">目标用户数</text>
        <input class="inp" type="number" placeholder="如 200" value="{{newStaffTarget}}" bindinput="onNewStaffTarget" />
        <block wx:if="{{newTier === 'L2'}}">
          <text class="lab lab-mt">挂靠</text>
          <picker mode="selector" range="{{parentPickerRange}}" range-key="label" value="{{parentPickerIndex}}" bindchange="onParentPick">
            <view class="picker-box">{{parentPickerRange[parentPickerIndex].label}}</view>
          </picker>
        </block>
        <button class="btn-pri btn-mt" bindtap="addStaff">加入团队</button>
      </view>

      <view class="panel panel-compact" wx:if="{{!isPrincipal}}">
        <text class="panel-h">团队</text>
        <text class="panel-s">分佣与加人仅主管可操作。您当前为 {{tierLabel}}。</text>
      </view>

      <view class="panel panel-compact">
        <text class="panel-h">一级员工 · {{staffL1.length}}</text>
        <view class="org-card" wx:for="{{staffL1}}" wx:key="phone">
          <view class="org-card-main" bindtap="goL1Detail" data-phone="{{item.phone}}">
            <text class="org-card-name">{{item.displayName}}</text>
            <text class="org-card-ph">{{item.phone}}</text>
            <text class="org-card-detail-hint">业绩与分佣明细 ›</text>
          </view>
          <view class="org-card-w" wx:if="{{isPrincipal}}">
            <text class="org-card-wk">比例%</text>
            <input
              class="org-card-wi"
              type="number"
              value="{{item.commissionPct}}"
              bindblur="onStaffPctBlur"
              data-phone="{{item.phone}}"
            />
          </view>
          <view class="org-card-w" wx:if="{{isPrincipal}}">
            <text class="org-card-wk">目标户</text>
            <input
              class="org-card-wi org-card-wi-narrow"
              type="number"
              placeholder="0"
              value="{{item.targetUserCount}}"
              bindblur="onStaffTargetBlur"
              data-phone="{{item.phone}}"
            />
          </view>
          <text class="org-card-wv" wx:else>比例 {{item.commissionPct}}% · 目标 {{item.targetUserCount}} 户</text>
        </view>
        <text class="empty" wx:if="{{!staffL1.length}}">暂无一级</text>
      </view>

      <view class="panel panel-compact">
        <text class="panel-h">二级员工 · {{staffL2.length}}</text>
        <view class="org-card" wx:for="{{staffL2}}" wx:key="phone">
          <view class="org-card-main">
            <text class="org-card-name">{{item.displayName}}</text>
            <text class="org-card-ph">{{item.phone}} · {{item.parentL1Phone === 'ROOT' ? '主管直线' : item.parentL1Phone}}</text>
          </view>
          <view class="org-card-w" wx:if="{{isPrincipal}}">
            <text class="org-card-wk">比例%</text>
            <input
              class="org-card-wi"
              type="number"
              value="{{item.commissionPct}}"
              bindblur="onStaffPctBlur"
              data-phone="{{item.phone}}"
            />
          </view>
          <view class="org-card-w" wx:if="{{isPrincipal}}">
            <text class="org-card-wk">目标户</text>
            <input
              class="org-card-wi org-card-wi-narrow"
              type="number"
              placeholder="0"
              value="{{item.targetUserCount}}"
              bindblur="onStaffTargetBlur"
              data-phone="{{item.phone}}"
            />
          </view>
          <text class="org-card-wv" wx:else>比例 {{item.commissionPct}}% · 目标 {{item.targetUserCount}} 户</text>
          <view class="org-card-act" wx:if="{{isPrincipal}}" data-phone="{{item.phone}}" bindtap="reassignL2">划拨</view>
        </view>
        <text class="empty" wx:if="{{!staffL2.length}}">暂无二级</text>
      </view>
    </block>

    <block wx:if="{{activeTab == 3}}">
      <view class="panel panel-compact">
        <text class="panel-h">待审入驻 · {{pendingCount}}</text>
        <block wx:if="{{pendingApps.length}}">
          <view class="app" wx:for="{{pendingApps}}" wx:key="id">
            <text class="app-t">{{item.shopTitle}}</text>
            <text class="app-m">商家 {{item.merchantMask}} · 邀请 {{item.inviterMask}}</text>
            <text class="app-m">{{item.createdAt}}</text>
            <view class="app-btns">
              <view class="ab ghost" data-id="{{item.id}}" bindtap="rejectApp">拒绝</view>
              <view class="ab ok" data-id="{{item.id}}" bindtap="approveApp">通过</view>
            </view>
          </view>
        </block>
        <text class="empty" wx:else>暂无</text>
      </view>
    </block>
  </view>

  <button class="foot" bindtap="toUser">切换到用户端</button>
</view>
