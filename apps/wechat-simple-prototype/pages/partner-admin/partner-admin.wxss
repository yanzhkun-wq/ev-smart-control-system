  flex-direction: row;
  gap: 16rpx;
}
.ab {
  flex: 1;
  text-align: center;
  padding: 18rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
  font-weight: 800;
}
.ab.ghost {
  background: #f1f5f9;
  color: #64748b;
}
.ab.ok {
  background: #0284c7;
  color: #fff;
}
.empty {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #94a3b8;
}
.p-chips {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}
.p-chip {
  padding: 12rpx 22rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #475569;
  background: #f1f5f9;
  border: 1rpx solid #e2e8f0;
}
.p-chip.on {
  background: #0f172a;
  color: #fff;
  border-color: #0f172a;
}
.p-custom {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}
.p-date {
  padding: 16rpx 20rpx;
  background: #f8fafc;
  border-radius: 10rpx;
  font-size: 24rpx;
  color: #334155;
  border: 1rpx solid #e2e8f0;
}
.p-query {
  padding: 16rpx 28rpx;
  background: #0284c7;
  color: #fff;
  font-size: 24rpx;
  font-weight: 800;
  border-radius: 10rpx;
}
.p-stat-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}
.p-si {
  width: calc(50% - 6rpx);
  background: #f8fafc;
  border-radius: 12rpx;
  padding: 18rpx 14rpx;
  box-sizing: border-box;
  border: 1rpx solid #e2e8f0;
}
.p-si-wide {
  width: 100%;
}
.p-sv {
  font-size: 30rpx;
  font-weight: 800;
  color: #0f172a;
  display: block;
}
.p-sk {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #64748b;
}
.split-inp-row {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-top: 16rpx;
}
.split-inp {
  flex: 1;
}
.inp-narrow {
  margin-top: 8rpx;
}
.btn-split {
  margin-top: 20rpx;
}
.ledger-scroll {
  margin-top: 14rpx;
  max-height: 900rpx;
}
.ld-row {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}
.ld-head {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}
.ld-kind {
  font-size: 22rpx;
  font-weight: 800;
  color: #fff;
  background: #6366f1;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.ld-time {
  font-size: 22rpx;
  color: #94a3b8;
}
.ld-line {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #334155;
  display: block;
}
.ld-inv {
  margin-top: 8rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #0f172a;
  display: block;
}

/* 合作商等级 · 进度 */
.tier-hero {
  margin: 16rpx 20rpx 12rpx;
  padding: 28rpx 24rpx 22rpx;
  background: linear-gradient(145deg, #0f172a 0%, #1e3a5f 55%, #172554 100%);
  border-radius: 16rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.22);
  box-shadow: 0 8rpx 32rpx rgba(15, 23, 42, 0.12);
}
.tier-hero-main {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-start;
}
.tier-left {
  flex: 1;
  min-width: 0;
}
.tier-badge {
  font-size: 44rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 2rpx;
  display: block;
}
.tier-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(226, 232, 240, 0.85);
  display: block;
}
.tier-right {
  text-align: right;
  flex-shrink: 0;
  padding-left: 16rpx;
}
.tier-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #38bdf8;
  display: block;
  line-height: 1.1;
}
.tier-num-cap {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: rgba(148, 163, 184, 0.95);
  display: block;
}
.tier-track {
  margin-top: 22rpx;
  height: 12rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.12);
  overflow: hidden;
}
.tier-fill {
  height: 100%;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #38bdf8 0%, #22d3ee 100%);
}
.tier-next {
  margin-top: 14rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: baseline;
  gap: 16rpx;
}
.tier-next-strong {
  font-size: 24rpx;
  font-weight: 700;
  color: rgba(248, 250, 252, 0.95);
  flex: 1;
  min-width: 0;
}
.tier-next-weak {
  font-size: 22rpx;
  color: rgba(148, 163, 184, 0.95);
  flex-shrink: 0;
}
.tier-max {
  margin-top: 18rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(226, 232, 240, 0.92);
  display: block;
}
.tier-meta {
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(148, 163, 184, 0.25);
  font-size: 22rpx;
  color: rgba(148, 163, 184, 0.88);
  display: block;
}

.foot {
  margin: 24rpx 20rpx 0;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 14rpx;
  font-weight: 800;
  background: #fff;
  color: #0f172a;
  border: 2rpx solid #94a3b8;
}
