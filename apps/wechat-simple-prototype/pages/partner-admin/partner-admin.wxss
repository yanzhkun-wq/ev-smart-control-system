  line-height: 88rpx;
  border-radius: 14rpx;
  font-weight: 800;
  color: #fff;
  background: #0f172a;
}
.gate-btn.ghost {
  background: #fff;
  color: #0f172a;
  border: 2rpx solid #cbd5e1;
}

.shell {
  min-height: 100vh;
  background: #e8edf3;
