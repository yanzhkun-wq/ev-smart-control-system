.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #eef2ff 0%, #f8fafc 40%);
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #e2e8f0;
  box-shadow: 0 8rpx 28rpx rgba(15, 23, 42, 0.06);
}

.hero-t {
  font-size: 34rpx;
  font-weight: 800;
  color: #0f172a;
  display: block;
}

.owner-row {
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #f1f5f9;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.owner-lab {
  font-size: 26rpx;
  color: #64748b;
}

.owner-val {
  font-size: 30rpx;
  font-weight: 800;
  color: #4f46e5;
  letter-spacing: 2rpx;
}

.lab {
  font-size: 26rpx;
  font-weight: 700;
  color: #334155;
  display: block;
  margin-bottom: 12rpx;
}

.lab-mt {
  margin-top: 20rpx;
}

.inp {
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  font-size: 30rpx;
}

.btn {
  margin-top: 32rpx;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: #fff;
  background: linear-gradient(135deg, #4f46e5, #6366f1);
}

.bad-t {
  font-size: 28rpx;
  color: #b91c1c;
  line-height: 1.5;
}
