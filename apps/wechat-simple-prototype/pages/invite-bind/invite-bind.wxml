<view class="page">
  <block wx:if="{{err}}">
    <view class="card bad">
      <text class="bad-t">{{err}}</text>
    </view>
  </block>

  <block wx:else>
    <view class="card hero">
      <text class="hero-t">用车邀请</text>
      <view class="owner-row">
        <text class="owner-lab">车主</text>
        <text class="owner-val">{{mainMasked}}</text>
      </view>
    </view>

    <view class="card form">
      <text class="lab">您的姓名</text>
      <input
        class="inp"
        placeholder="方便车主辨认"
        maxlength="20"
        value="{{riderName}}"
        bindinput="onNameInput"
      />
      <text class="lab lab-mt">手机号</text>
      <input
        class="inp"
        type="number"
        maxlength="11"
        placeholder="11 位手机号"
        value="{{riderPhone}}"
        bindinput="onPhoneInput"
      />
      <button class="btn" bindtap="onBind">确认绑定</button>
    </view>
  </block>
</view>
