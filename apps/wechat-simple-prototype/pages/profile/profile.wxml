<view class="shell safe-bottom">

  <view class="profile-hero" style="padding-top: {{navPadTop}}px;">

    <view class="profile-card">

      <view class="profile-main">

        <view class="avatar-wrap">
          <view class="avatar">{{user.avatarText}}</view>
        </view>

        <view class="profile-info">

          <view class="profile-name-row">
            <text class="display-name">{{user.name}}</text>
          </view>

          <text class="account-id">账号 {{user.id}}</text>

          <view class="tag-row">
            <text class="tag tag-primary">{{user.role}}</text>
          </view>

        </view>

      </view>

      <view class="login-banner" wx:if="{{!isLoggedIn}}" bindtap="goLogin">
        <text class="login-banner-t">登录后可管理车辆、查看告警与轨迹</text>
        <text class="login-banner-a">去首页登录 ›</text>
      </view>

    </view>

  </view>

  <!-- 数据统计 -->
  <view class="stats-row" wx:if="{{isLoggedIn}}">
    <view class="stats-item">
      <text class="stats-num">{{vehicleCount || 0}}</text>
      <text class="stats-lbl">绑定车辆</text>
    </view>
    <view class="stats-item">
      <text class="stats-num">{{alarmPending}}</text>
      <text class="stats-lbl">待处理告警</text>
    </view>
    <view class="stats-item">
      <text class="stats-num">{{user.name !== '游客' ? '1' : '0'}}</text>
      <text class="stats-lbl">车队</text>
    </view>
  </view>

  <view class="panel panel-compact">
    <view class="panel-head panel-head-min">
      <text class="panel-title">{{ui.sectionServices}}</text>
    </view>
    <view class="grid-4">
      <view class="gcell" bindtap="go" data-url="/pages/tracks/tracks">
        <view class="gcell-ico gcell-indigo"><text class="gcell-char">{{ui.tracksIcon}}</text></view>
        <text class="gcell-name">{{ui.tracksName}}</text>
      </view>
      <view class="gcell gcell-dot-wrap" bindtap="go" data-url="/pages/alarm/alarm">
        <view class="gcell-ico gcell-amber"><text class="gcell-char">{{ui.alarmIcon}}</text></view>
        <text class="gcell-name">{{ui.alarmName}}</text>
        <view class="dot" wx:if="{{alarmPending > 0}}">{{alarmPending}}</view>
      </view>
      <view class="gcell" bindtap="go" data-url="/pages/fence-edit/fence-edit">
        <view class="gcell-ico gcell-teal"><text class="gcell-char">{{ui.fenceIcon}}</text></view>
        <text class="gcell-name">{{ui.fenceName}}</text>
      </view>
      <view class="gcell" bindtap="go" data-url="/pages/auth/auth">
        <view class="gcell-ico gcell-sky"><text class="gcell-char">{{ui.authIcon}}</text></view>
        <text class="gcell-name">{{ui.authName}}</text>
      </view>
    </view>
  </view>


  <view class="panel panel-compact panel-mall-pair">
    <view class="panel-head panel-head-min">
      <text class="panel-title">{{ui.sectionHardware}}</text>
    </view>
    <view class="mall-pair">
      <view class="pair-item" bindtap="go" data-url="/pages/hardware/hardware">
        <view class="pair-ico pair-ico-emerald"><text class="pair-char">{{ui.hardwareIcon}}</text></view>
        <text class="pair-name">{{ui.hardwareName}}</text>
      </view>
    </view>
  </view>


  <view class="panel panel-compact panel-tight">
    <view class="panel-head panel-head-min">
      <text class="panel-title">{{ui.sectionSystem}}</text>
    </view>
    <view class="list list-compact">
      <view class="litem" wx:if="{{!isLoggedIn}}" bindtap="goLogin">
        <view class="litem-ico litem-indigo"><text>{{ui.sysLoginIcon}}</text></view>
        <view class="litem-body">
          <text class="litem-title">{{ui.sysLoginTitle}}</text>
        </view>
        <text class="litem-arr">›</text>
      </view>
      <view class="litem" bindtap="go" data-url="/pages/account/account">
        <view class="litem-ico litem-slate"><text>{{ui.sysAccountIcon}}</text></view>
        <view class="litem-body">
          <text class="litem-title">{{ui.sysAccountTitle}}</text>
        </view>
        <text class="litem-arr">›</text>
      </view>
      <view class="litem" bindtap="go" data-url="/pages/notify/notify">
        <view class="litem-ico litem-rose"><text>{{ui.sysNotifyIcon}}</text></view>
        <view class="litem-body">
          <text class="litem-title">{{ui.sysNotifyTitle}}</text>
        </view>
        <text class="litem-arr">›</text>
      </view>
      <view class="litem" wx:if="{{isLoggedIn}}" bindtap="logoutDemo">
        <view class="litem-ico litem-mute"><text>{{ui.sysLogoutIcon}}</text></view>
        <view class="litem-body">
          <text class="litem-title litem-warn">{{ui.sysLogoutTitle}}</text>
        </view>
        <text class="litem-arr">›</text>
      </view>
    </view>
  </view>


  <view class="footer-meta">
    <text class="footer-line">电动车安全守护 · 开源公益项目</text>
  </view>

</view>


<main-tabbar active="{{1}}" />
