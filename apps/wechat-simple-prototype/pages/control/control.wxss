.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.head {
  padding: 32rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.model {
  font-size: 34rpx;
  font-weight: 700;
  display: block;
}

.plate {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #6b7280;
  display: block;
}

.remote {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.btn {
  flex: 1;
  border-radius: 24rpx;
  padding: 40rpx 20rpx;
  text-align: center;
}

.unlock {
  background: linear-gradient(135deg, #8b7cf6 0%, #6366f1 100%);
  color: #fff;
  box-shadow: 0 12rpx 32rpx rgba(99, 102, 241, 0.25);
}

.lock {
  background: #f3f4f6;
  color: #374151;
}

.ico {
  font-size: 52rpx;
  display: block;
}

.txt {
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: block;
}

.sec {
  padding: 8rpx 0 16rpx;
}

.st {
  display: block;
  padding: 20rpx 28rpx 8rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.line {
  display: flex;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-top: 1rpx solid #f3f4f6;
  font-size: 26rpx;
}

.ok {
  color: #16a34a;
  font-weight: 600;
}

.hint {
  margin-top: 24rpx;
  font-size: 22rpx;
  color: #9ca3af;
  text-align: center;
}
