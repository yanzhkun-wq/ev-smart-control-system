.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: linear-gradient(180deg, #eef2f7 0%, #f8fafc 35%);
}

.safe-bottom {
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 28rpx rgba(15, 23, 42, 0.06);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
}

/* vehicle head */
.head {
  padding: 32rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.model {
  font-size: 34rpx;
  font-weight: 700;
  display: block;
  color: #0f172a;
}

.plate {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #64748b;
  display: block;
}

.online-badge {
  display: inline-block;
  margin-top: 12rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.online-badge.online {
  background: #f0fdf4;
  color: #10b981;
}

.online-badge.offline {
  background: #f1f5f9;
  color: #94a3b8;
}

/* remote controls */
.remote-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.remote-btn {
  flex: 1;
  border-radius: 24rpx;
  padding: 36rpx 16rpx;
  text-align: center;
  background: #fff;
  box-shadow: 0 8rpx 28rpx rgba(15, 23, 42, 0.06);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
  transition: all 0.2s;
}

.remote-btn.active {
  background: linear-gradient(135deg, #8b7cf6 0%, #6366f1 100%);
  color: #fff;
  box-shadow: 0 12rpx 32rpx rgba(99, 102, 241, 0.25);
  border-color: transparent;
}

.remote-btn.danger {
  border-color: #fecaca;
}

.remote-btn.secondary {
  background: #f8fafc;
}

.remote-btn.loading {
  opacity: 0.6;
}

.ico {
  font-size: 48rpx;
  display: block;
}

.txt {
  margin-top: 8rpx;
  font-size: 26rpx;
  font-weight: 600;
  display: block;
}

/* device status */
.sec {
  padding: 8rpx 0 16rpx;
}

.st {
  display: block;
  padding: 20rpx 28rpx 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.line {
  display: flex;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-top: 1rpx solid #f1f5f9;
  font-size: 26rpx;
  color: #475569;
}

.ok {
  color: #10b981;
  font-weight: 600;
}

.err {
  color: #ef4444;
  font-weight: 600;
}

.hint {
  margin-top: 24rpx;
  font-size: 22rpx;
  color: #94a3b8;
  text-align: center;
}
