.gate {
  min-height: 100vh;
  background: #e8edf3;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}
.gate-inner {
  width: 100%;
  max-width: 640rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  border: 1rpx solid #e2e8f0;
}
.gate-t {
  font-size: 32rpx;
  font-weight: 800;
  color: #0f172a;
  display: block;
  text-align: center;
}
.gate-s {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.5;
  display: block;
}
.gate-btn {
  margin-top: 28rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 14rpx;
  font-weight: 800;
  color: #fff;
  background: #0f172a;
}
.gate-btn.ghost {
  background: #fff;
  color: #0f172a;
  border: 2rpx solid #cbd5e1;
}

.page {
  height: 100vh;
  background: #e8edf3;
  box-sizing: border-box;
}
.hero {
  background: linear-gradient(145deg, #1e293b 0%, #0f172a 100%);
  padding: 36rpx 28rpx 40rpx;
}
.hero-k {
  font-size: 24rpx;
  color: rgba(226, 232, 240, 0.85);
  display: block;
}
.hero-v {
  margin-top: 12rpx;
  font-size: 56rpx;
  font-weight: 800;
  color: #fff;
  display: block;
}
.hero-meta {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: rgba(148, 163, 184, 0.95);
  display: block;
  word-break: break-all;
}

.bind-panel:active {
  opacity: 0.96;
}
.bind-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}
.bind-go {
  font-size: 24rpx;
  font-weight: 700;
  color: #0284c7;
}
.bind-title {
  margin-top: 12rpx;
  font-size: 28rpx;
  font-weight: 800;
  color: #0f172a;
  display: block;
}
.bind-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #475569;
  display: block;
}
.bind-warn {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #b45309;
  line-height: 1.45;
  display: block;
}
.bind-tip {
  margin-top: 14rpx;
}
.bind-muted {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.45;
  display: block;
}

.panel {
  margin: 16rpx 20rpx 0;
  background: #fff;
  border-radius: 16rpx;
  padding: 22rpx;
  border: 1rpx solid #cbd5e1;
}
.ph {
  font-size: 28rpx;
  font-weight: 800;
  color: #0f172a;
  display: block;
}
.ps {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #64748b;
  line-height: 1.45;
  display: block;
}
.hint {
  margin-top: 16rpx;
  font-size: 20rpx;
  color: #94a3b8;
  line-height: 1.45;
  display: block;
}
.stat-line {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}
.stat-line:last-of-type {
  border-bottom: none;
}
.sk {
  font-size: 24rpx;
  color: #64748b;
}
.sv {
  font-size: 26rpx;
  font-weight: 800;
  color: #0f172a;
}

.row-input {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
}
.inp {
  flex: 1;
  height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  font-size: 28rpx;
  background: #f8fafc;
}
.btn-ghost {
  padding: 0 24rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #0369a1;
  background: #e0f2fe;
  border-radius: 12rpx;
}
.btn-pri {
  margin-top: 20rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 14rpx;
  font-weight: 800;
  background: #0f172a;
  color: #fff;
}
.btn-pri[disabled] {
  background: #94a3b8;
  color: #f1f5f9;
}

.wd {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f1f5f9;
}
.wd:first-of-type {
  margin-top: 16rpx;
  padding-top: 0;
  border-top: none;
}
.wd-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}
.wd-amt {
  font-size: 32rpx;
  font-weight: 800;
  color: #0f172a;
}
.wd-pill {
  font-size: 20rpx;
  font-weight: 700;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  background: #fef3c7;
  color: #b45309;
}
.wd-pill.paid {
  background: #d1fae5;
  color: #047857;
}
.wd-pill.pend {
  background: #e0f2fe;
  color: #0369a1;
}
.wd-pill.rej {
  background: #f1f5f9;
  color: #64748b;
}
.wd-line {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #334155;
  display: block;
}
.wd-payto {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #0369a1;
  font-weight: 600;
  display: block;
}
.wd-meta {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #64748b;
  display: block;
}
.wd-time {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #94a3b8;
  display: block;
}
.wd-note {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #b45309;
  display: block;
}
.wd-btns {
  margin-top: 14rpx;
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}
.wb {
  flex: 1;
  font-size: 26rpx;
  font-weight: 700;
  border-radius: 12rpx;
  padding: 16rpx 0;
}
.wb::after {
  border: none;
}
.wb.ghost {
  background: #f1f5f9;
  color: #64748b;
}
.wb.ok {
  background: #0284c7;
  color: #fff;
}

.empty {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #94a3b8;
  text-align: center;
  padding: 20rpx 0;
}
.foot-spacer {
  height: calc(40rpx + env(safe-area-inset-bottom));
}
