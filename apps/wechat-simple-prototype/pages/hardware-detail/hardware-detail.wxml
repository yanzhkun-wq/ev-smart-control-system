<view class="page" wx:if="{{product}}">
  <swiper
    class="hero-swiper"
    indicator-dots="{{heroSlides.length > 1}}"
    indicator-color="rgba(255,255,255,.45)"
    indicator-active-color="#fff"
    circular="{{heroSlides.length > 1}}"
    autoplay="{{heroSlides.length > 1}}"
    interval="4000"
  >
    <swiper-item wx:for="{{heroSlides}}" wx:for-item="slide" wx:for-index="sx" wx:key="sx">
      <image wx:if="{{slide}}" class="hero-img" src="{{slide}}" mode="aspectFill" />
      <view wx:else class="hero-ph {{thumbClass}}">
        <text class="hero-ph-t">兼容硬件</text>
        <text class="hero-ph-s">示意图待完善 · 以实物为准</text>
      </view>
    </swiper-item>
  </swiper>

  <view class="panel">
    <text class="title">{{product.name}}</text>
    <text class="subtitle">{{product.subtitle}}</text>
    <view class="tags" wx:if="{{product.tags && product.tags.length}}">
      <text class="tag" wx:for="{{product.tags}}" wx:key="*this">{{item}}</text>
    </view>
  </view>

  <view class="panel">
    <text class="sec-title">兼容说明</text>
    <text class="intro">{{product.desc}}</text>
  </view>

  <view class="panel detail-panel">
    <text class="sec-title">详细信息</text>
    <text class="detail-body">{{product.detail}}</text>
  </view>

  <view class="bottom-safe"></view>
</view>
