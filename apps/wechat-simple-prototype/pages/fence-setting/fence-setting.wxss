.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: linear-gradient(180deg, #eef2f7 0%, #f8fafc 35%);
}

.safe-bottom {
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 28rpx rgba(15, 23, 42, 0.06);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
}

/* fence item */
.fence {
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
}

.fence-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.fence-l {
  flex: 1;
}

.fence-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  display: block;
}

.fence-disabled {
  color: #94a3b8;
}

.fence-addr {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #64748b;
  display: block;
}

.fence-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.fence-status.on {
  background: #f0fdf4;
  color: #10b981;
}

.fence-status.off {
  background: #f1f5f9;
  color: #94a3b8;
}

.fence-meta {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.meta-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  background: #f1f5f9;
  border-radius: 8rpx;
  color: #475569;
}

.fence-del {
  font-size: 24rpx;
  color: #ef4444;
  text-align: right;
}

.del-press {
  opacity: 0.5;
}

/* empty */
.empty {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  display: block;
}

.empty-t {
  margin-top: 16rpx;
  font-size: 30rpx;
  color: #0f172a;
  display: block;
}

.empty-s {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #94a3b8;
  display: block;
}

.add-btn {
  margin-top: 8rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #7c6cf7 0%, #6366f1 50%, #4f46e5 100%);
  color: #fff;
}

/* editor overlay */
.overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 99;
}

.editor {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 80vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 100;
  display: flex;
  flex-direction: column;
}

.editor-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.editor-cancel {
  font-size: 28rpx;
  color: #64748b;
}

.editor-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.editor-save {
  font-size: 28rpx;
  color: #3b82f6;
  font-weight: 600;
}

.editor-body {
  padding: 24rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.field {
  margin-bottom: 28rpx;
}

.field-label {
  font-size: 26rpx;
  color: #475569;
  display: block;
  margin-bottom: 12rpx;
}

.field-input {
  height: 80rpx;
  padding: 0 20rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: 1rpx solid #e2e8f0;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  padding: 0 20rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: 1rpx solid #e2e8f0;
  color: #0f172a;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.slider-row {
  padding: 0 8rpx;
}
