.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.box {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.label {
  font-size: 28rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}

.hint {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #9ca3af;
  line-height: 1.5;
  display: block;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
}

.save {
  margin-top: 16rpx;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 999rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #7c6cf7 0%, #6366f1 50%, #4f46e5 100%);
  color: #fff;
}
