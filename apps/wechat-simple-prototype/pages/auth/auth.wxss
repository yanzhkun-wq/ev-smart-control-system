.page {
  min-height: 100vh;
  max-height: 100vh;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: linear-gradient(180deg, #e8ecf7 0%, #f3f4f8 100%);
}

.safe-bottom {
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 26rpx 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.95);
  box-shadow: 0 8rpx 28rpx rgba(15, 23, 42, 0.06);
}

.intro-t {
  font-size: 34rpx;
  font-weight: 800;
  color: #0f172a;
  display: block;
}

.owner-chip-row {
  margin-top: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.owner-chip-lab {
  font-size: 24rpx;
  color: #64748b;
}

.owner-chip-val {
  font-size: 28rpx;
  font-weight: 800;
  color: #4f46e5;
  letter-spacing: 1rpx;
}

.link-account {
  margin-top: 16rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0 4rpx;
}

.link-account-t {
  font-size: 26rpx;
  color: #6366f1;
  font-weight: 700;
}

.link-account-arr {
  font-size: 32rpx;
  color: #a5b4fc;
}

.block-t {
  font-size: 30rpx;
  font-weight: 800;
  color: #0f172a;
  display: block;
}

.add-card .block-t + .add-inp {
  margin-top: 16rpx;
}

.add-inp {
  height: 88rpx;
  padding: 0 22rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  font-size: 28rpx;
  box-sizing: border-box;
}

.add-inp-mt {
  margin-top: 16rpx;
}

.add-btn {
  margin-top: 20rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 800;
  color: #fff;
  background: linear-gradient(135deg, #0d9488, #14b8a6);
}

.share-compact .block-t {
  margin-bottom: 16rpx;
}

.share-row {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  gap: 20rpx;
}

.share-qr {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
  border-radius: 12rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}

.share-side {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 16rpx;
}

.share-btn-sm {
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 800;
  color: #fff;
  background: linear-gradient(135deg, #4f46e5, #6366f1);
  padding: 0;
  margin: 0;
}

.share-btn-sm::after {
  border: none;
}

.copy-inline {
  text-align: center;
  padding: 16rpx;
  border-radius: 14rpx;
  background: #f1f5f9;
  border: 1rpx solid #e2e8f0;
}

.copy-inline-t {
  font-size: 26rpx;
  color: #475569;
  font-weight: 700;
}

.empty-list {
  padding: 20rpx 0 8rpx;
  font-size: 26rpx;
  color: #94a3b8;
}

.row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.row:last-child {
  border-bottom: none;
}

.row-mid {
  flex: 1;
  min-width: 0;
}

.row-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #0f172a;
  display: block;
}

.row-phone {
  margin-top: 6rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #475569;
  display: block;
}

.row-meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #94a3b8;
  display: block;
}

.row-del {
  flex-shrink: 0;
  margin-top: 4rpx;
  padding: 14rpx 22rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #b91c1c;
  background: #fef2f2;
  border: 1rpx solid #fecaca;
}

.rider-card {
  border-left: 6rpx solid #6366f1;
}

.rider-t {
  font-size: 32rpx;
  font-weight: 800;
  color: #0f172a;
  display: block;
}

.rider-one {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #64748b;
  display: block;
}
