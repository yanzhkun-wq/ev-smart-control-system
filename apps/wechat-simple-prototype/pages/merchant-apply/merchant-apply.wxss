.mpa-page {
  padding: 24rpx;
  min-height: 100vh;
  background: #eef2f7;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #e2e8f0;
}

.mpa-intro {
  border-left: 6rpx solid #2563eb;
}

.mpa-warn {
  background: #fffbeb;
  border-color: #fde68a;
}

.mpa-kicker {
  font-size: 22rpx;
  font-weight: 700;
  color: #2563eb;
  letter-spacing: 2rpx;
  display: block;
}

.mpa-h {
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 800;
  color: #0f172a;
  display: block;
}

.mpa-p {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.5;
  display: block;
}

.mpa-sub {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.45;
  display: block;
}

.mpa-sec {
  font-size: 26rpx;
  font-weight: 800;
  color: #0f172a;
  margin-bottom: 8rpx;
  display: block;
}

.mpa-session {
  margin-top: 22rpx;
  padding: 20rpx 22rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}

.mpa-session-k {
  font-size: 22rpx;
  font-weight: 700;
  color: #64748b;
  display: block;
}

.mpa-session-v {
  margin-top: 8rpx;
  font-size: 32rpx;
  font-weight: 800;
  color: #0f172a;
  letter-spacing: 2rpx;
  display: block;
}

.mpa-session-h {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #94a3b8;
  line-height: 1.4;
  display: block;
}

.lab {
  font-size: 26rpx;
  font-weight: 700;
  color: #334155;
  display: block;
  margin-bottom: 12rpx;
}

.lab-mt {
  margin-top: 20rpx;
}

.inp {
  height: 88rpx;
  padding: 0 22rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  font-size: 28rpx;
  box-sizing: border-box;
}

.ta {
  min-height: 180rpx;
  height: auto;
  padding: 20rpx 22rpx;
  line-height: 1.5;
}

.mpa-btn {
  margin-top: 28rpx;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 12rpx;
  font-weight: 800;
  font-size: 28rpx;
  color: #fff;
  background: #0f172a;
  border: none;
}

.mpa-btn-ghost {
  margin-top: 18rpx;
  background: #fff;
  color: #0f172a;
  border: 2rpx solid #e2e8f0;
}

.img-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
}

.img-add {
  width: 200rpx;
  height: 200rpx;
  border-radius: 14rpx;
  border: 2rpx dashed #cbd5e1;
  background: #f8fafc;
  display: flex;
  align-items: center;
  justify-content: center;
}

.img-add-t {
  font-size: 26rpx;
  color: #64748b;
  font-weight: 600;
}

.img-wrap {
  position: relative;
}

.img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 14rpx;
  display: block;
}

.img-re {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #2563eb;
  font-weight: 600;
}

.loc-pick {
  min-height: 88rpx;
  padding: 20rpx 22rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.loc-pick-t {
  flex: 1;
  font-size: 26rpx;
  color: #334155;
  line-height: 1.4;
  min-width: 0;
}

.loc-pick-a {
  font-size: 24rpx;
  font-weight: 700;
  color: #2563eb;
  flex-shrink: 0;
}
