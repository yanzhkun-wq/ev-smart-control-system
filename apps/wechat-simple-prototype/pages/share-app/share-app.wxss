.login-card {
  padding: 28rpx;
}

.login-card .t {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  display: block;
  margin-bottom: 24rpx;
}

.login-card .btn {
  margin: 0;
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 12rpx;
  font-weight: 700;
  color: #fff;
  background: #111827;
}

.login-card .btn::after {
  border: none;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #eef2f6;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 0;
  margin-bottom: 20rpx;
  border: 1rpx solid #e5e7eb;
  overflow: hidden;
}

.rewards-head {
  padding: 24rpx 28rpx 20rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.rewards-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  letter-spacing: 0.02em;
}

.rewards-sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #64748b;
}

.tier-row {
  display: flex;
  flex-direction: row;
  align-items: stretch;
}

.tier-cell {
  flex: 1;
  padding: 24rpx 12rpx 28rpx;
  text-align: center;
}

.tier-v {
  width: 1rpx;
  background: #f1f5f9;
  align-self: stretch;
}

.tier-top {
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.tier-num {
  font-size: 44rpx;
  font-weight: 800;
  color: #111827;
  line-height: 1;
}

.tier-unit {
  margin-left: 4rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #64748b;
}

.tier-line {
  font-size: 24rpx;
  font-weight: 600;
  color: #334155;
  display: block;
}

.tier-note {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #64748b;
  display: block;
}

.prog {
  padding: 22rpx 28rpx 26rpx;
}

.prog-head {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 14rpx;
}

.prog-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #475569;
}

.prog-cta {
  font-size: 28rpx;
  font-weight: 800;
  color: #0f172a;
  font-variant-numeric: tabular-nums;
}

.prog-bar-bg {
  height: 10rpx;
  border-radius: 999rpx;
  background: #e5e7eb;
  overflow: hidden;
}

.prog-bar-in {
  height: 100%;
  border-radius: 999rpx;
  background: #111827;
}

.prog-foot {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #64748b;
}

.invite-hero-box {
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  border: 1rpx solid #e5e7eb;
}

.invite-hero-img {
  width: 100%;
  display: block;
  vertical-align: top;
}

.share-panel {
  padding: 28rpx;
}

.share-grid {
  display: flex;
  flex-direction: row;
  gap: 28rpx;
  align-items: flex-start;
}

.qr {
  width: 176rpx;
  height: 176rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  flex-shrink: 0;
  border: 1rpx solid #e5e7eb;
}

.share-col {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.acct {
  font-size: 26rpx;
  font-weight: 600;
  color: #334155;
}

.share-btn {
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
  background: #111827;
}

.share-btn::after {
  border: none;
}

.copy {
  text-align: center;
  padding: 14rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #475569;
  background: #f1f5f9;
}
