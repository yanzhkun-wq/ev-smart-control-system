<view class="gate" wx:if="{{!ok}}">
  <view class="gate-inner">
    <block wx:if="{{loadError}}">
      <text class="gate-t">客户装机查询</text>
      <text class="gate-s">{{loadError}}</text>
      <button class="gate-btn" bindtap="retryGate">重试</button>
    </block>
    <block wx:else>
      <text class="gate-t">校验中…</text>
    </block>
  </view>
</view>

<view class="shell" wx:if="{{ok}}">
  <view class="hint-card">
    <text class="hint-line">查询本合作商名下网点产生的装机记录；拓客员工仅区分一级/二级岗位，业绩归属合作商体系。</text>
  </view>

  <view class="search-bar">
    <input
      class="search-input"
      type="text"
      placeholder="手机号（精确）或车牌 / 网点名 / 店主名"
      value="{{query}}"
      bindinput="onQueryInput"
      confirm-type="search"
      bindconfirm="doSearch"
    />
    <button class="search-btn" bindtap="doSearch">查询</button>
  </view>

  <view class="empty" wx:if="{{searched && emptyHint}}">{{emptyHint}}</view>

  <view class="card" wx:for="{{rows}}" wx:key="rowKey">
    <view class="card-head">
      <text class="card-kind" wx:if="{{item.kind === 'install_job'}}">装机</text>
      <text class="card-kind card-kind-soft" wx:else>邀请</text>
      <text class="card-plate">{{item.plate}}</text>
    </view>
    <view class="row">
      <text class="k">用户</text>
      <text class="v">{{item.userPhoneMask}}</text>
    </view>
    <view class="row" wx:if="{{item.kind === 'install_job'}}">
      <text class="k">装机时间</text>
      <text class="v">{{item.installAt}}</text>
    </view>
    <view class="row" wx:if="{{item.kind === 'invite_only'}}">
      <text class="k">邀请登记</text>
      <text class="v">{{item.inviteRegisteredAt}}</text>
    </view>
    <view class="row" wx:if="{{item.kind === 'install_job'}}">
      <text class="k">网点</text>
      <text class="v">{{item.shopName}} · 店主 {{item.bossNameHint}}</text>
    </view>
    <view class="row" wx:if="{{item.kind === 'install_job'}}">
      <text class="k">店主账号</text>
      <text class="v">{{item.merchantPhoneMask}}</text>
    </view>
    <view class="row">
      <text class="k">拓客归属</text>
      <text class="v">{{item.staffLabel}}</text>
    </view>
    <view class="row muted">
      <text class="k">来源</text>
      <text class="v">{{item.installSourceLabel}}</text>
    </view>
    <text class="tier-note">{{item.staffTierHint}}</text>
  </view>
</view>
