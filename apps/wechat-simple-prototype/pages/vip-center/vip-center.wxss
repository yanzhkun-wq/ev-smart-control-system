page {
  min-height: 100vh;
  background-color: #eef2f6;
}

.vip-root {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/** 使用 vip-card，避免被全局 app.wxss 的 .card 覆盖排版导致样式错乱 */
.vip-card {
  background: #fff;
  border-radius: 16rpx;
  border: 1rpx solid #e5e7eb;
  margin-bottom: 20rpx;
}

.err-card {
  padding: 36rpx 28rpx;
}

.err-t {
  font-size: 30rpx;
  font-weight: 800;
  color: #b45309;
  display: block;
  margin-bottom: 16rpx;
}

.err-s {
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.45;
  display: block;
  margin-bottom: 28rpx;
}

.login-card {
  padding: 36rpx 28rpx;
}

.login-t {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
  display: block;
  margin-bottom: 28rpx;
}

.login-btn {
  margin: 0;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 12rpx;
  font-weight: 700;
  color: #fff;
  background: #111827;
}

.login-btn::after {
  border: none;
}

.status-card {
  padding: 28rpx;
}

.status-k {
  font-size: 22rpx;
  font-weight: 600;
  color: #64748b;
  display: block;
  margin-bottom: 12rpx;
}

.status-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #0f172a;
  letter-spacing: 0.02em;
  display: block;
  line-height: 1.25;
}

.status-sub {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #475569;
  line-height: 1.45;
  display: block;
}

.sec-label {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #64748b;
  margin: 8rpx 4rpx 14rpx;
  letter-spacing: 0.02em;
}

.benefit {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 22rpx 20rpx;
  gap: 18rpx;
}

.benefit-ico {
  width: 76rpx;
  height: 76rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.08);
}

.benefit-ico-teal {
  background: linear-gradient(145deg, #2dd4bf, #14b8a6);
}

.benefit-ico-sky {
  background: linear-gradient(145deg, #38bdf8, #0ea5e9);
}

.benefit-char {
  font-size: 28rpx;
  font-weight: 800;
  color: #fff;
}

.benefit-body {
  flex: 1;
  min-width: 0;
}

.benefit-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
  display: block;
  line-height: 1.3;
}

.benefit-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.45;
  display: block;
}

.benefit-arr {
  font-size: 32rpx;
  color: #cbd5e1;
  flex-shrink: 0;
  margin-top: 8rpx;
}

.cta {
  padding: 26rpx 24rpx 28rpx;
}

.cta-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #0f172a;
  display: block;
}

.cta-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #334155;
  line-height: 1.45;
  display: block;
}

.cta-more {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #94a3b8;
  line-height: 1.4;
  display: block;
}

.cta-btn {
  margin-top: 22rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
  background: #111827;
}

.cta-btn::after {
  border: none;
}

.cta-soft {
  padding-top: 22rpx;
}

.cta-soft-t {
  font-size: 24rpx;
  color: #475569;
  line-height: 1.45;
  display: block;
}

.cta-btn-outline {
  background: #fff;
  color: #111827;
  border: 2rpx solid #e5e7eb;
}

.cta-btn-pay {
  margin-top: 22rpx;
  background: linear-gradient(135deg, #d97706 0%, #b45309 100%);
  color: #fff;
}

.pay-cta {
  border: 1rpx solid rgba(217, 119, 6, 0.25);
  background: linear-gradient(180deg, #fffbeb 0%, #fff 48%);
}
