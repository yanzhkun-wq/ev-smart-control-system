.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #eef2ff, #f8fafc);
}
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #e2e8f0;
}
.t {
  font-size: 32rpx;
  font-weight: 800;
  color: #0f172a;
  display: block;
}
.s {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.45;
  display: block;
}
.row {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f1f5f9;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.lab {
  font-size: 26rpx;
  font-weight: 700;
  color: #334155;
  display: block;
  margin-bottom: 12rpx;
}
.lab-mt {
  margin-top: 20rpx;
}
.val {
  font-size: 28rpx;
  font-weight: 800;
  color: #4f46e5;
}
.inp {
  height: 88rpx;
  padding: 0 22rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  font-size: 28rpx;
}
.warn {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #b45309;
  display: block;
}
.err {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #b91c1c;
  display: block;
}
.btn {
  margin-top: 28rpx;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 16rpx;
  font-weight: 800;
  color: #fff;
  background: linear-gradient(135deg, #4f46e5, #6366f1);
}
.bad-t {
  color: #b91c1c;
  font-size: 28rpx;
}
