<view class="page" wx:if="{{ok && stats}}">
  <view class="head">
    <text class="head-t">{{label}}</text>
    <text class="head-s">直营 = 本账号直接邀请；二级 = 下属二级员工邀请带来的门店/用户/结算。</text>
  </view>

  <view class="kpi-grid">
    <view class="kpi">
      <text class="kpi-v">{{stats.merchantTotal}}</text>
      <text class="kpi-k">绑定商家</text>
    </view>
    <view class="kpi">
      <text class="kpi-v">{{stats.userTotal}}</text>
      <text class="kpi-k">邀请用户</text>
    </view>
    <view class="kpi kpi-wide">
      <text class="kpi-v">¥{{stats.rewardTotal}}</text>
      <text class="kpi-k">奖励合计（档位{{partnerRateLabel}}）</text>
    </view>
  </view>

  <view class="panel">
    <text class="panel-h">结构拆解</text>
    <view class="tbl">
      <view class="tr th">
        <text class="td">维度</text>
        <text class="td">直营</text>
        <text class="td">二级</text>
        <text class="td">小计</text>
      </view>
      <view class="tr">
        <text class="td">商家数</text>
        <text class="td">{{stats.merchantDirect}}</text>
        <text class="td">{{stats.merchantL2}}</text>
        <text class="td strong">{{stats.merchantTotal}}</text>
      </view>
      <view class="tr">
        <text class="td">用户数</text>
        <text class="td">{{stats.userDirect}}</text>
        <text class="td">{{stats.userL2}}</text>
        <text class="td strong">{{stats.userTotal}}</text>
      </view>
      <view class="tr">
        <text class="td">奖励</text>
        <text class="td">¥{{stats.rewardDirect}}</text>
        <text class="td">¥{{stats.rewardL2}}</text>
        <text class="td strong">¥{{stats.rewardTotal}}</text>
      </view>
    </view>
  </view>

  <view class="panel" wx:if="{{stats.l2Members.length}}">
    <text class="panel-h">下属二级员工（{{stats.l2Members.length}}）</text>
    <view class="l2-row" wx:for="{{stats.l2Members}}" wx:key="phone">
      <text class="l2-name">{{item.displayName}}</text>
      <text class="l2-ph">{{item.phone}}</text>
    </view>
  </view>

  <view class="panel">
    <text class="panel-h">本线收入流水（逐笔）</text>
    <scroll-view scroll-y class="scroll-rw" wx:if="{{rewardRows.length}}">
      <view class="rw" wx:for="{{rewardRows}}" wx:key="id">
        <view class="rw-top">
          <text class="rw-amt">+¥{{item.rewardYuan}}</text>
          <text class="rw-tag {{item.sourceType === '直营' ? 'tag-d' : 'tag-s'}}">{{item.sourceType}}</text>
        </view>
        <text class="rw-line">商家 {{item.merchantMask}} · 计提基数 ¥{{item.orderAmountYuan}}</text>
        <text class="rw-line dim">邀请人 {{item.inviterMask}} · 归属线 {{item.bucketLabel}} · {{item.settledAt}}</text>
      </view>
    </scroll-view>
    <text class="empty" wx:else>暂无流水</text>
  </view>
</view>
