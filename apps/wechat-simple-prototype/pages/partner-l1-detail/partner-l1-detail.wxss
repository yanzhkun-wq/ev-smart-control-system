.page {
  min-height: 100vh;
  padding: 0 0 40rpx;
  background: #f1f5f9;
}
.head {
  padding: 28rpx 24rpx 20rpx;
  background: #0f172a;
}
.head-t {
  font-size: 34rpx;
  font-weight: 800;
  color: #fff;
  display: block;
}
.head-s {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: rgba(226, 232, 240, 0.85);
  line-height: 1.45;
  display: block;
}
.kpi-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 20rpx 24rpx;
}
.kpi {
  width: calc(50% - 8rpx);
  background: #fff;
  border-radius: 14rpx;
  padding: 22rpx;
  box-sizing: border-box;
  border: 1rpx solid #e2e8f0;
}
.kpi-wide {
  width: 100%;
}
.kpi-v {
  font-size: 40rpx;
  font-weight: 800;
  color: #0f172a;
  display: block;
}
.kpi-k {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #64748b;
}
.panel {
  margin: 0 24rpx 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 22rpx;
  border: 1rpx solid #e2e8f0;
}
.panel-h {
  font-size: 28rpx;
  font-weight: 800;
  color: #0f172a;
  margin-bottom: 16rpx;
  display: block;
}
.tbl {
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  overflow: hidden;
}
.tr {
  display: flex;
  flex-direction: row;
  border-bottom: 1rpx solid #f1f5f9;
}
.tr:last-child {
  border-bottom: none;
}
.tr.th {
  background: #f8fafc;
}
.td {
  flex: 1;
  padding: 16rpx 10rpx;
  font-size: 22rpx;
  color: #475569;
  text-align: center;
  border-right: 1rpx solid #f1f5f9;
}
.td:last-child {
  border-right: none;
}
.td.strong {
  font-weight: 800;
  color: #0f172a;
}
.l2-row {
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
}
.l2-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #334155;
}
.l2-ph {
  font-size: 24rpx;
  color: #64748b;
}
.scroll-rw {
  max-height: 900rpx;
}
.rw {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}
.rw-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}
.rw-amt {
  font-size: 30rpx;
  font-weight: 800;
  color: #059669;
}
.rw-tag {
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.tag-d {
  background: #dbeafe;
  color: #1d4ed8;
}
.tag-s {
  background: #ffedd5;
  color: #c2410c;
}
.rw-line {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #475569;
  display: block;
}
.rw-line.dim {
  color: #94a3b8;
  font-size: 20rpx;
}
.empty {
  font-size: 24rpx;
  color: #94a3b8;
  padding: 20rpx 0;
}
