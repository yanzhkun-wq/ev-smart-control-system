.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: linear-gradient(180deg, #eef2f7 0%, #f8fafc 35%);
}

.safe-bottom {
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 28rpx rgba(15, 23, 42, 0.06);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
}

.filter-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.filter-item {
  padding: 12rpx 28rpx;
  background: #fff;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #64748b;
  border: 1rpx solid #e2e8f0;
}

.filter-on {
  background: #3b82f6;
  color: #fff;
  border-color: #3b82f6;
}

.loading {
  text-align: center;
  padding: 80rpx 0;
  color: #94a3b8;
  font-size: 28rpx;
}

.record {
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
}

.record-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.action-tag {
  font-size: 28rpx;
  font-weight: 700;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

.tag-lock {
  background: #fef2f2;
  color: #ef4444;
}

.tag-unlock {
  background: #f0fdf4;
  color: #10b981;
}

.record-time {
  font-size: 24rpx;
  color: #94a3b8;
}

.record-meta {
  display: flex;
  gap: 24rpx;
  margin-bottom: 12rpx;
}

.meta-item {
  font-size: 26rpx;
  color: #475569;
}

.record-loc {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.loc-icon {
  font-size: 24rpx;
}

.loc-text {
  font-size: 24rpx;
  color: #64748b;
}

.empty {
  text-align: center;
  padding: 80rpx 0;
  color: #94a3b8;
  font-size: 28rpx;
}
