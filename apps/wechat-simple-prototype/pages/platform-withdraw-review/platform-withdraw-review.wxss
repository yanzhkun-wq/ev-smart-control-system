.gate {
  min-height: 100vh;
  padding: 48rpx 32rpx;
  box-sizing: border-box;
  background: #f1f5f9;
}
.gate-inner {
  background: #fff;
  border-radius: 16rpx;
  padding: 36rpx;
  border: 1rpx solid #e2e8f0;
}
.gate-t {
  font-size: 32rpx;
  font-weight: 800;
  color: #0f172a;
  display: block;
}
.gate-s {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.5;
  display: block;
}
.gate-btn {
  margin-top: 28rpx;
}
.gate-btn.ghost {
  background: #f1f5f9;
  color: #334155;
  border: 2rpx solid #cbd5e1;
  border-radius: 12rpx;
  font-weight: 700;
}

.page {
  height: 100vh;
  background: #f1f5f9;
  box-sizing: border-box;
}
.banner {
  margin: 20rpx;
  padding: 22rpx;
  background: #eff6ff;
  border: 1rpx solid #bfdbfe;
  border-radius: 14rpx;
}
.banner-t {
  font-size: 28rpx;
  font-weight: 800;
  color: #1e40af;
  display: block;
}
.banner-s {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #3b82f6;
  line-height: 1.45;
  display: block;
}

.panel {
  margin: 0 20rpx 16rpx;
  padding: 22rpx;
  background: #fff;
  border-radius: 14rpx;
  border: 1rpx solid #e2e8f0;
}
.row-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}
.amt {
  font-size: 34rpx;
  font-weight: 800;
  color: #0f172a;
}
.pill {
  font-size: 20rpx;
  font-weight: 700;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  background: #fef3c7;
  color: #b45309;
}
.line {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #334155;
  display: block;
}
.payto {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #0369a1;
  font-weight: 600;
  display: block;
}
.meta {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #64748b;
  display: block;
}
.time {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
  display: block;
}
.btns {
  margin-top: 16rpx;
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}
.b {
  flex: 1;
  font-size: 26rpx;
  font-weight: 700;
  border-radius: 12rpx;
  padding: 16rpx 0;
}
.b::after {
  border: none;
}
.b.ghost {
  background: #f1f5f9;
  color: #64748b;
}
.b.ok {
  background: #2563eb;
  color: #fff;
}
.empty {
  text-align: center;
  font-size: 26rpx;
  color: #94a3b8;
  padding: 40rpx 0;
}
.sp {
  height: calc(40rpx + env(safe-area-inset-bottom));
}
