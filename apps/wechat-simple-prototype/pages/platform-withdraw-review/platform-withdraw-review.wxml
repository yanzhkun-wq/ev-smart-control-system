<view class="gate" wx:if="{{!ok && (denied || loadError)}}">
  <view class="gate-inner">
    <text class="gate-t">平台·提现审核</text>
    <text class="gate-s">{{loadError || '无法访问'}}</text>
    <button class="gate-btn ghost" bindtap="goBack">返回</button>
  </view>
</view>

<scroll-view scroll-y class="page" wx:if="{{ok}}">
  <view class="banner">
    <text class="banner-t">待平台审核</text>
    <text class="banner-s">须在电脑管理后台「运营与分销 → 提现审核」对照渠道流水/门店后再打款；手机端仅演示，勿跳过对账。</text>
  </view>

  <view class="panel" wx:if="{{!list.length}}">
    <text class="empty">暂无待审核提现</text>
  </view>

  <view class="panel" wx:for="{{list}}" wx:key="id">
    <view class="row-top">
      <text class="amt">¥{{item.amountYuanStr}}</text>
      <text class="pill">待审核</text>
    </view>
    <text class="line">体系 {{item.rootSystemMask}}</text>
    <text class="line">{{item.applicantLabel}} {{item.applicantMask}}</text>
    <text class="payto" wx:if="{{item.payoutSummary}}">收款：{{item.payoutSummary}}</text>
    <text class="meta" wx:if="{{item.walletAuditLine}}">{{item.walletAuditLine}}</text>
    <text class="meta" wx:if="{{item.wxMetaLine}}">{{item.wxMetaLine}}</text>
    <text class="time">{{item.createdAt}}</text>
    <view class="btns">
      <button class="b ghost" data-id="{{item.id}}" bindtap="rejectPay">驳回</button>
      <button class="b ok" data-id="{{item.id}}" data-summary="{{item.payoutSummary}}" bindtap="confirmPay">确认打款</button>
    </view>
  </view>

  <view class="sp"></view>
</scroll-view>
