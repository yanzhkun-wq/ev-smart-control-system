<view class="page">
  <view class="hint card">
    <text class="hint-t">演示：维护上架商品</text>
    <text class="hint-s">可上传主图、修改文案与详情。保存后商城首页与详情页同步更新。</text>
  </view>

  <block wx:for="{{products}}" wx:key="id">
    <view class="row card" bindtap="openForm" data-id="{{item.id}}">
      <image wx:if="{{item.mainImage}}" class="row-img" src="{{item.mainImage}}" mode="aspectFill" />
      <view wx:else class="row-img row-ph {{item.thumbClass}}"><text>图</text></view>
      <view class="row-body">
        <text class="row-title">{{item.name}}</text>
        <text class="row-sub">¥{{item.price}} / {{item.unit}}</text>
        <text class="row-arr">编辑 ›</text>
      </view>
    </view>
  </block>
</view>
