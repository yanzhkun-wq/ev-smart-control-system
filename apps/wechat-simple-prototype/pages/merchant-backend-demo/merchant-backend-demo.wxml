<view class="ma-page" wx:if="{{ok}}">
  <view class="ma-header">
    <text class="ma-brand">升级网点工作台</text>
    <text class="ma-tagline">设备入库 · 客户服务 · 补贴与账务</text>
    <text class="ma-login">登录账号 {{phoneMask}}</text>
  </view>

  <view class="ma-finance" bindtap="goWallet">
    <view class="ma-fin-left">
      <text class="ma-fin-title">资金中心</text>
      <text class="ma-fin-desc">补贴入账明细 · 提现申请 · 收款账户管理</text>
    </view>
    <text class="ma-fin-arrow">›</text>
  </view>

  <view class="ma-card">
    <view class="ma-card-head">
      <text class="ma-step">01</text>
      <view class="ma-card-head-text">
        <text class="ma-card-title">门店档案</text>
        <text class="ma-card-sub">{{shopLine}}</text>
      </view>
      <text class="ma-card-action" bindtap="goEditShop">编辑资料</text>
    </view>
  </view>

  <view class="ma-card">
    <view class="ma-card-head">
      <text class="ma-step">02</text>
      <view class="ma-card-head-text">
        <text class="ma-card-title">设备入库</text>
        <text class="ma-card-sub">改装前先扫码，编码记入本店库存，每台设备仅可入库一次。</text>
      </view>
    </view>
    <button class="ma-btn ma-btn-primary" bindtap="scanBindDevice">扫码录入设备</button>
    <block wx:if="{{inventory.length}}">
      <text class="ma-mini-title">当前库存编码</text>
      <view class="ma-tags">
        <text class="ma-tag" wx:for="{{inventory}}" wx:key="id">{{item.deviceCode}}</text>
      </view>
    </block>
    <text class="ma-empty" wx:else>暂无库存，请先扫码入库。</text>
  </view>

  <view class="ma-card">
    <view class="ma-card-head">
      <text class="ma-step">03</text>
      <view class="ma-card-head-text">
        <text class="ma-card-title">登记客户服务单</text>
        <text class="ma-card-sub">绑定车主手机号、设备编码与车牌；编码须来自上方库存。</text>
      </view>
    </view>
    <text class="ma-field-label">服务类型</text>
    <view class="ma-seg">
      <view class="ma-seg-i {{installSegIndex === 0 ? 'on' : ''}}" data-i="0" bindtap="setInstallSeg">到店改装（补贴）</view>
      <view class="ma-seg-i {{installSegIndex === 1 ? 'on' : ''}}" data-i="1" bindtap="setInstallSeg">本店客户（线下）</view>
    </view>
    <text class="ma-hint" wx:if="{{installSegIndex === 0}}">到店改装（上门客源）：平台按 {{walkInSubsidyHint}} 计提，约合 ¥{{walkInSubsidyYuan}}/单（演示）；结算见「资金中心」。</text>
    <text class="ma-hint" wx:if="{{installSegIndex === 1}}">本店邀约不产生平台补贴；与用户线下收款即可。</text>

    <text class="ma-field-label">车主手机号</text>
    <input class="ma-input" type="number" maxlength="11" placeholder="车主账号手机号" value="{{fUserPhone}}" bindinput="onFUserPhone" />
    <text class="ma-field-label">设备编码</text>
    <input class="ma-input" placeholder="须与库存中编码一致" value="{{fCode}}" bindinput="onFCode" />
    <text class="ma-field-label">车牌号码</text>
    <input class="ma-input" placeholder="与车主端填写一致" value="{{fPlate}}" bindinput="onFPlate" />

    <button class="ma-btn ma-btn-submit" bindtap="submitBind">提交登记</button>
  </view>

  <view class="ma-card ma-card-last">
    <text class="ma-section-title">客户服务记录</text>
    <text class="ma-section-note">店内加装服务进度；涉及平台到店补贴（基数×比例）的，入账请在「资金中心」核对。</text>
    <block wx:if="{{jobs.length === 0}}">
      <text class="ma-empty">暂无记录</text>
    </block>
    <block wx:for="{{jobs}}" wx:key="id">
      <view class="ma-job">
        <view class="ma-job-row1">
          <text class="ma-job-plate">{{item.plate}}</text>
          <text class="ma-pill ma-pill-{{item.statusTone}}">{{item.statusLabel}}</text>
        </view>
        <text class="ma-job-line">{{item.serviceTypeLabel}} · {{item.userPhoneMask}}</text>
        <text class="ma-job-line">{{item.econLine}}</text>
        <text class="ma-job-time">{{item.displayTime}}</text>
        <view class="ma-job-actions" wx:if="{{item.status === 'pending_online'}}">
          <button class="ma-mini" size="mini" bindtap="markOnline" data-id="{{item.id}}">确认设备已联网</button>
        </view>
        <view class="ma-job-actions" wx:if="{{item.status === 'valid'}}">
          <button class="ma-mini ma-mini-strong" size="mini" bindtap="markSettled" data-id="{{item.id}}">{{item.settleBtnLabel}}</button>
        </view>
      </view>
    </block>
  </view>

  <button class="ma-switch-user" bindtap="toUser">切换到用户端</button>
</view>
