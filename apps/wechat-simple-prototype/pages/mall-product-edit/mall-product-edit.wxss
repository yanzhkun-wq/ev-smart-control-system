.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #f0f2f5;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #e2e8f0;
}

.hint-t {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  color: #0f172a;
}

.hint-s {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.5;
}

.row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
}

.row-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #f1f5f9;
}

.row-ph {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
  color: #fff;
}

.row-ph.tw-gw {
  background: linear-gradient(145deg, #10b981, #047857);
}
.row-ph.tw-ctrl {
  background: linear-gradient(145deg, #6366f1, #4338ca);
}
.row-ph.tw-kit {
  background: linear-gradient(145deg, #fbbf24, #d97706);
}
.row-ph.tw-def {
  background: linear-gradient(145deg, #64748b, #475569);
}

.row-body {
  flex: 1;
  min-width: 0;
}

.row-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #0f172a;
}

.row-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #dc2626;
  font-weight: 700;
}

.row-arr {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #4f46e5;
  font-weight: 700;
}
