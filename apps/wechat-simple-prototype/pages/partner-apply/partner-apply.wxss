.page {
  padding: 24rpx;
  min-height: 100vh;
  background: #f3f4f8;
}
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #e2e8f0;
}
.t {
  font-size: 32rpx;
  font-weight: 800;
  color: #0f172a;
  display: block;
}
.s {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.45;
  display: block;
}
.lab {
  font-size: 26rpx;
  font-weight: 700;
  color: #334155;
  display: block;
  margin-bottom: 12rpx;
}
.lab-mt {
  margin-top: 20rpx;
}
.inp {
  height: 88rpx;
  padding: 0 22rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  font-size: 28rpx;
  box-sizing: border-box;
}
.ta {
  min-height: 200rpx;
  height: auto;
  padding: 20rpx 22rpx;
  line-height: 1.5;
}
.ro {
  font-size: 28rpx;
  font-weight: 700;
  color: #4f46e5;
}
.btn {
  margin-top: 28rpx;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 16rpx;
  font-weight: 800;
  color: #fff;
  background: linear-gradient(135deg, #0d9488, #14b8a6);
}
