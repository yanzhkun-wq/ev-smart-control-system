.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
  background: #f0f2f5;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #e2e8f0;
}

.lab {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #334155;
  margin-bottom: 12rpx;
}

.lab-mt {
  margin-top: 20rpx;
}

.img-row {
  display: flex;
  flex-direction: row;
}

.main-img {
  width: 240rpx;
  height: 240rpx;
  border-radius: 16rpx;
  background: #f1f5f9;
}

.main-add {
  width: 240rpx;
  height: 240rpx;
  border-radius: 16rpx;
  border: 2rpx dashed #cbd5e1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #64748b;
  font-weight: 600;
}

.img-tip {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #94a3b8;
  line-height: 1.4;
}

.inp {
  height: 88rpx;
  padding: 0 22rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  font-size: 28rpx;
  box-sizing: border-box;
}

.ta {
  min-height: 160rpx;
  padding: 20rpx 22rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  font-size: 28rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

.ta-lg {
  min-height: 360rpx;
}

.save {
  margin-top: 8rpx;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 16rpx;
  font-weight: 800;
  font-size: 30rpx;
  color: #fff;
  background: linear-gradient(135deg, #4f46e5, #6366f1);
}
