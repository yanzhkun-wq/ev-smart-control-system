.bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 12rpx 0 calc(12rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -8rpx 32rpx rgba(15, 23, 42, 0.06);
  border-top: 1rpx solid #eef0f4;
}

.item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
  text-decoration: none;
  color: #64748b;
}

.item.on {
  color: #3730a3;
}

.item.on .txt {
  font-weight: 700;
}

.ico {
  font-size: 40rpx;
  line-height: 1.2;
}

.txt {
  font-size: 22rpx;
  margin-top: 4rpx;
}
