# ============================================
# 电动车安全守护系统 — 环境变量配置
# 复制为 .env 文件后填入真实值：
#   cp .env.example .env
# ============================================

# ---------- 微信小程序（必填）----------
# 在微信公众平台注册小程序后获取
WECHAT_MP_APPID=wx_your_appid_here
WECHAT_MP_SECRET=your_app_secret_here

# ---------- 设备网关 ----------
# 设备 TCP 长连接端口（云端必须放行此端口）
GATEWAY_PORT=7611

# HTTP API 端口（内网使用，建议不暴露公网）
HTTP_PORT=7612

# 设备注册鉴权码：设备首次接入时需要携带此码
# 建议设为 16 位以上随机字符串（字母+数字+符号）
REGISTER_AUTH_CODE=请替换为高强度鉴权码

# 数据持久化目录（容器内路径，自动映射到宿主机 volume）
DATA_DIR=/data
