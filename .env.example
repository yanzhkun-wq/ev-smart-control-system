# ============================================
# 电动车智控系统 — 环境变量配置模板
# 部署到服务器前，把下面内容复制为 .env 文件并填入真实值
# ============================================

# --- 微信小程序（注册小程序后获取）---
WECHAT_MP_APPID=wx_your_appid_here
WECHAT_MP_SECRET=your_app_secret_here

# --- 设备网关 ---
# 硬件设备连接端口（云端须放行 TCP，腾讯轻量控制台 → 防火墙 → 添加规则）
GATEWAY_PORT=7611

# HTTP API 端口（内部使用，可选对外）
HTTP_PORT=7612

# 设备鉴权码：设备首次注册时需要带这个密码才能接入
REGISTER_AUTH_CODE=请替换为高强度鉴权码（建议随机16位字母数字组合）

# 数据存储目录
DATA_DIR=/data